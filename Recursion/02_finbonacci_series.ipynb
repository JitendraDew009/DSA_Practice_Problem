   "source": [
    "def fibonacciSeries(n):\n",
    "    # base case condition\n",
    "    if n <= 1:\n",
    "        return n\n",
    "    else:\n",
    "        return fibonacciSeries(n-1) + fibonacciSeries(n-2)\n",
    "\n",
    "# Driver_code\n",
    "n = 10\n",
    "for i in range(n):\n",
    "    print(fibonacciSeries(i)) "
   ]
