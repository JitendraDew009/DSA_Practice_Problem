   ],
   "source": [
    "arr = [70, 20, 50, 30, 90, 5, 15]\n",
    "n = len(arr)\n",
    "\n",
    "for i in range(n-1):\n",
    "    for j in range(i+1, n):\n",
    "        if arr[i] > arr[j]:\n",
    "            arr[i], arr[j] = arr[j], arr[i]\n",
    "\n",
    "print(\"Sorted array:\", arr)"
   ]
  },
